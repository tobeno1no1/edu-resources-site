---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '小学初中教辅资料免费分享站，每日更新，涵盖语数英等各科目练习卷、知识点、真题。' } = Astro.props;

// 修复 BASE_URL 缺斜杠问题：确保末尾有 /
// import.meta.env.BASE_URL 在某些 Astro 版本下返回 `/edu-resources-site`（无尾斜杠）
const rawBase = import.meta.env.BASE_URL;
const BASE = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// 网站部署的根路径（用于搜索 API 的绝对路径）
const SITE_BASE = rawBase.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} - 教辅资料站</title>
  <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
</head>
<body>
  <!-- 顶部导航 -->
  <header style="border-bottom: 1px solid var(--color-border); background: #fff; position: sticky; top: 0; z-index: 100;">
    <div style="max-width: var(--max-width); margin: 0 auto; padding: 0 20px; height: var(--header-height); display: flex; align-items: center; justify-content: space-between; gap: 16px;">
      <a href={BASE} style="font-size: 17px; font-weight: 600; color: var(--color-text-primary); text-decoration: none; display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
        📚 教辅资料站
      </a>

      <!-- 搜索框 -->
      <div style="flex: 1; max-width: 360px; position: relative;">
        <input
          type="text"
          id="search-input"
          placeholder="搜索资料（年级/科目/关键词）"
          autocomplete="off"
          style="width: 100%; padding: 7px 12px 7px 32px; border: 1px solid var(--color-border-dark); border-radius: 20px; font-size: 13px; outline: none; transition: border-color 0.15s;"
        />
        <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted); font-size: 14px; pointer-events: none;">🔍</span>
        <!-- 搜索结果下拉框 -->
        <div id="search-results" style="display: none; position: absolute; top: calc(100% + 6px); left: 0; right: 0; background: #fff; border: 1px solid var(--color-border); border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); max-height: 480px; overflow-y: auto; z-index: 200;"></div>
      </div>

      <nav style="display: flex; align-items: center; gap: 4px; flex-shrink: 0;">
        <a href={BASE} class="btn" style="border: none; font-size: 14px;">首页</a>
        <a href={`${BASE}grade/1`} class="btn" style="border: none; font-size: 14px;">按年级</a>
        <a href={`${BASE}daily`} class="btn" style="border: none; font-size: 14px;">每日更新</a>
      </nav>
    </div>
  </header>

  <!-- 主体内容 -->
  <main style="flex: 1; max-width: var(--max-width); margin: 0 auto; padding: 32px 20px; width: 100%;">
    <slot />
  </main>

  <!-- 底部 -->
  <footer style="border-top: 1px solid var(--color-border); padding: 24px 20px; text-align: center; font-size: 13px; color: var(--color-text-muted);">
    <p>📚 教辅资料站 · 免费公益分享 · 每日更新</p>
    <p style="margin-top: 4px;">资料来源于网络，仅供学习交流，如有版权问题请联系删除</p>
  </footer>

  <!-- 搜索功能脚本 -->
  <script define:vars={{ SITE_BASE }}>
    (function() {
      const input = document.getElementById('search-input');
      const resultsBox = document.getElementById('search-results');
      let searchIndex = null;
      let searchTimer = null;

      // 加载搜索索引
      async function loadIndex() {
        if (searchIndex) return searchIndex;
        try {
          const res = await fetch(`${SITE_BASE}/search-index.json`);
          searchIndex = await res.json();
          return searchIndex;
        } catch (e) {
          console.error('搜索索引加载失败', e);
          return [];
        }
      }

      // 简单的高亮函数
      function highlight(text, query) {
        if (!query) return text;
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        return text.replace(new RegExp(escaped, 'gi'), m => `<mark style="background:#fef08a;padding:0 2px;">${m}</mark>`);
      }

      // 搜索匹配函数（标题/标签/科目/品牌/类型）
      function searchResources(items, query) {
        const q = query.toLowerCase().trim();
        if (!q) return [];
        return items.filter(item => {
          const haystack = [
            item.title, item.subject, item.brand, item.type,
            item.gradeLabel || '', item.date
          ].join(' ').toLowerCase();
          return haystack.includes(q);
        }).slice(0, 8);
      }

      // 渲染结果
      function renderResults(results, query) {
        if (results.length === 0) {
          resultsBox.innerHTML = `<div style="padding: 20px; text-align: center; color: var(--color-text-muted); font-size: 13px;">未找到相关资料</div>`;
          resultsBox.style.display = 'block';
          return;
        }
        const html = results.map(r => `
          <a href="${r.link}" target="_blank" rel="noopener noreferrer" style="display: flex; gap: 12px; padding: 10px 12px; border-bottom: 1px solid var(--color-border); text-decoration: none; color: inherit; transition: background 0.12s; align-items: center;" onmouseover="this.style.background='#f8f9fa'" onmouseout="this.style.background='#fff'">
            ${r.cover ? `<img src="${r.cover}" alt="" style="width: 64px; height: 45px; object-fit: cover; border-radius: 4px; flex-shrink: 0;" loading="lazy" />` : '<div style="width: 64px; height: 45px; background: #f1f3f5; border-radius: 4px; flex-shrink: 0;"></div>'}
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 13px; font-weight: 500; color: var(--color-text-primary); line-height: 1.4; margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">${highlight(r.title, query)}</div>
              <div style="display: flex; flex-wrap: wrap; gap: 4px; font-size: 11px; color: var(--color-text-muted);">
                <span>${r.subject}</span>
                <span>·</span>
                <span>${r.gradeLabel}</span>
                <span>·</span>
                <span>${r.type}</span>
              </div>
            </div>
          </a>
        `).join('');
        resultsBox.innerHTML = html;
        resultsBox.style.display = 'block';
      }

      // 监听输入
      input.addEventListener('input', (e) => {
        const query = e.target.value;
        clearTimeout(searchTimer);
        if (!query.trim()) {
          resultsBox.style.display = 'none';
          return;
        }
        searchTimer = setTimeout(async () => {
          const index = await loadIndex();
          const results = searchResources(index, query);
          renderResults(results, query);
        }, 150);
      });

      // 点击外部关闭
      document.addEventListener('click', (e) => {
        if (!e.target.closest('#search-input') && !e.target.closest('#search-results')) {
          resultsBox.style.display = 'none';
        }
      });

      // 回车跳转到 /search?q=xxx
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && input.value.trim()) {
          window.location.href = `${SITE_BASE}/search?q=${encodeURIComponent(input.value.trim())}`;
        }
      });

      // 输入框聚焦效果
      input.addEventListener('focus', () => {
        input.style.borderColor = 'var(--color-accent)';
        if (input.value.trim() && resultsBox.innerHTML) {
          resultsBox.style.display = 'block';
        }
      });
      input.addEventListener('blur', () => {
        input.style.borderColor = 'var(--color-border-dark)';
      });
    })();
  </script>
</body>
</html>
